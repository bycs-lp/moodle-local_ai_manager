 /**
  * Reactive mutation handlers for block_ai_chat.
@@ -45,6 +46,80 @@ class Mutations {
         stateManager.processUpdates(ajaxresult);
     }
 
+    // MBS-10761: Tool-agent mutations -----------------------------------------
+
+    /**
+     * Toggle between "chat" and "agent" mode.
+     *
+     * @param {object} stateManager
+     * @param {string} mode 'chat' or 'agent'
+     */
+    async setMode(stateManager, mode) {
+        stateManager.setReadOnly(false);
+        stateManager.state.config.mode = mode;
+        stateManager.setReadOnly(true);
+    }
+
+    /**
+     * Approve a pending tool call identified by its HMAC token.
+     *
+     * @param {object} stateManager
+     * @param {number} runid
+     * @param {number} callindex
+     * @param {string} token HMAC approval token
+     */
+    async approveToolCall(stateManager, runid, callindex, token) {
+        this.setLoadingState(stateManager, true);
+        const result = await callExternalFunctionReactiveUpdate(
+            'local_ai_manager_agent_approve_tool_call',
+            {runid, callindex, token}
+        );
+        stateManager.processUpdates(result);
+        this.setLoadingState(stateManager, false);
+    }
+
+    /**
+     * Reject a pending tool call.
+     *
+     * @param {object} stateManager
+     * @param {number} runid
+     * @param {number} callindex
+     * @param {string} reason optional free-text reason
+     */
+    async rejectToolCall(stateManager, runid, callindex, reason) {
+        const result = await callExternalFunctionReactiveUpdate(
+            'local_ai_manager_agent_reject_tool_call',
+            {runid, callindex, reason: reason || ''}
+        );
+        stateManager.processUpdates(result);
+    }
+
+    /**
+     * Grant trust for a tool in a given scope.
+     *
+     * @param {object} stateManager
+     * @param {string} toolname
+     * @param {string} scope 'session' | 'user' | 'global'
+     */
+    async trustTool(stateManager, toolname, scope) {
+        const result = await Ajax.call([{
+            methodname: 'local_ai_manager_agent_trust_tool',
+            args: {toolname, scope}
+        }])[0];
+        stateManager.setReadOnly(false);
+        stateManager.state.agent.trusted[toolname] = result;
+        stateManager.setReadOnly(true);
+    }
+
+    /**
+     * Undo a previously-executed reversible tool call.
+     *
+     * @param {object} stateManager
+     * @param {number} runid
+     * @param {number} callindex
+     */
+    async undoToolCall(stateManager, runid, callindex) {
+        const result = await callExternalFunctionReactiveUpdate(
+            'local_ai_manager_agent_undo_tool_call',
+            {runid, callindex}
+        );
+        stateManager.processUpdates(result);
+    }
+
     async selectCurrentPersonaAndLoadChat(stateManager, personaid) {
