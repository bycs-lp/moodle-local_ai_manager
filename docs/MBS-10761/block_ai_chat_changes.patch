     public function request_ai(string $prompt, array $options, int $conversationid, bool $isnew): array {
+        // MBS-10761: Dispatch to toolagent purpose when agent mode is enabled.
+        if (!empty($options['mode']) && $options['mode'] === 'agent') {
+            if (!has_capability('block/ai_chat:useagentmode', $this->context)) {
+                throw new \required_capability_exception(
+                    $this->context,
+                    'block/ai_chat:useagentmode',
+                    'nopermissions',
+                    ''
+                );
+            }
+            $orchestrator = \core\di::get(\local_ai_manager\agent\orchestrator::class);
+            return $orchestrator->run(
+                prompt: $prompt,
+                conversationid: $conversationid,
+                context: $this->context,
+                component: 'block_ai_chat',
+                options: $options,
+            );
+        }
         // ... existing chat-purpose flow ...
     }
