diff --git a/templates/agent_approval_card.mustache b/templates/agent_approval_card.mustache
new file mode 100644
--- /dev/null
+++ b/templates/agent_approval_card.mustache
@@ -0,0 +1,40 @@
+{{!
+    @template block_ai_chat/agent_approval_card
+
+    Approval card rendered for a pending tool call. The server supplies:
+      - toolname
+      - describeForUser (localised, untrusted -> escaped upstream)
+      - affectedObjects  [{type, label}, ...]
+      - approvalToken    (HMAC, opaque)
+      - runid, callindex
+
+    @package    block_ai_chat
+    @copyright  2026 ISB Bayern
+    @author     Dr. Peter Mayer
+    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
+}}
+<div class="agent-approval-card card mb-2"
+     data-action="agent-approval"
+     data-runid="{{runid}}"
+     data-callindex="{{callindex}}"
+     data-token="{{approvalToken}}">
+    <div class="card-body">
+        <h5 class="card-title">{{#str}} agentwillperform, block_ai_chat {{/str}}</h5>
+        <p>{{describeForUser}}</p>
+        {{#affectedObjects.length}}
+            <ul class="list-unstyled small">
+                {{#affectedObjects}}
+                    <li><strong>{{type}}:</strong> {{label}}</li>
+                {{/affectedObjects}}
+            </ul>
+        {{/affectedObjects.length}}
+        <div class="btn-group">
+            <button class="btn btn-primary" data-action="agent-approve">{{#str}} approve, block_ai_chat {{/str}}</button>
+            <button class="btn btn-secondary" data-action="agent-reject">{{#str}} reject, block_ai_chat {{/str}}</button>
+            {{#trustable}}
+                <button class="btn btn-link" data-action="agent-trust-session">{{#str}} alwaystrustsession, block_ai_chat {{/str}}</button>
+            {{/trustable}}
+        </div>
+    </div>
+</div>

